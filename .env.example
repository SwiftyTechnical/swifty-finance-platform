# Copy to `.env` and fill in real values. The .env file is git-ignored.

# Payment-gateway (Nixxe) API key. Read by the server when calling
# https://gateway-api.nixxe.io for any connection with a client_id.
GATEWAY_API_KEY=

# Optional overrides
# GATEWAY_BASE_URL=https://gateway-api.nixxe.io
# GATEWAY_MODE=prod

# Disable in-server auto-refresh scheduler if you don't want background fetches.
# SWIFTY_DISABLE_SCHEDULER=0

# --- AWS Cognito auth (shared user pool with the ai-agents compliance portal) ---
# Users must belong to the "FinanceAdmin" Cognito group to access the app.
AWS_REGION=eu-west-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
# The server also needs AWS IAM credentials at runtime for the Admin* Cognito
# calls (or a configured ~/.aws profile / instance role in production):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
