# Copy to `.env` and fill in real values. The .env file is git-ignored.

# Payment-gateway (Nixxe) API key. Read by the server when calling
# https://gateway-api.nixxe.io for any connection with a client_id.
GATEWAY_API_KEY=

# Optional overrides
# GATEWAY_BASE_URL=https://gateway-api.nixxe.io
# GATEWAY_MODE=prod

# Disable in-server auto-refresh scheduler if you don't want background fetches.
# SWIFTY_DISABLE_SCHEDULER=0
